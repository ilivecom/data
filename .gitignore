# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual env ───────────────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Secrets — NEVER commit these ─────────────────────────────────────────────
scripts/credentials.json
scripts/config.json
credentials.json
*.p12
*.pem
*.key
.env
.env.*
!.env.example

# ── Generated data ────────────────────────────────────────────────────────────
# public/etf-data.json and scripts/cn-trade-dates.json are intentionally NOT ignored:
#   GitHub Actions and the local scheduler both rely on committed JSON outputs and
#   a checked-in CN trading-calendar cache for holiday/make-up-day correctness.
#   If running a dedicated server instead, adjust these ignore rules accordingly.

# ── Local update log ──────────────────────────────────────────────────────────
.update.log

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
